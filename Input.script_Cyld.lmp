# Input file for uniaxial tensile loading of single crystal aluminum
clear                           # This command deletes all atoms, restores all settings to their default values, and frees all memory allocated by LAMMPS

# ------------------------ INITIALIZATION ----------------------------
units 		metal               # it can be lj or real or metal or si or cgs or electron or micro or nano
dimension	3                   # 2 (2-D), 3 (3-D) materials
boundary	p	p	p           # p(periodic), s(shrink-wrapped), f(fixed)
atom_style	atomic              # applicable for atomic liquids, solids, metals # Nothing to do with that
variable latparam equal 4.05    # Declearing a variable, name= latparam (it can be named anything)

# ----------------------- ATOM (System) DEFINITION ----------------------------
           
region		Box block 0 50 0 50 0 100 units box   # This command defines a geometric region of space
create_box	3 Box                       # Define No. of atom types in the 'Box'


lattice 	fcc ${latparam} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1
region cyl cylinder z 25 25 25 INF INF units box   # MidPoint-X plane, MidPoint-Y; Radius on 50x50 plane
create_atoms	1 region cyl    # filled up the cyl by atom type 1 (same function as 'set')


#group Box_1 region Box             # Use for Box shaped object deformation
#create_atoms	1 region Box 


region lw block INF INF INF INF INF 5 units box     # creating a lower fixed region
set region lw type 2                                # set command is to assign the 'atom type' in the "lw" region
group lw_gr region lw                               # Need to  group the region to use it in "fix" command
fix lw_fix lw_gr  setforce 0.0 0.0 0.0              # Before using "fix" command, you need to group that region first
             
                                    
                                    

region up block INF INF INF INF 95 INF units box    # creating a upper fixed region
set region up type 3                                # set command is to assign the 'atom type 2' in the "up" region
group up_gr region up
fix up_fix up_gr setforce 0.0 0.0 0.0


group Up_lw union up_gr lw_gr                       # using "union", merge two groups (up_gr + lw_gr)
group middle subtract all Up_lw                     # creat a deformable region named as "middle"


mass 1 26.98        # atom type 1
mass 2 26.98        # atom type 2
mass 3 26.98        # atom type 3


write_data structure_Al.lmpdat nocoeff     # To save the stucture data

# ------------------------ FORCE FIELDS ------------------------------
pair_style	eam/alloy                           # fixed style based on type of potential file e.g. eam, meam, tersoff etc.
pair_coeff	* * Al99.eam.alloy.txt Al Al Al     # Default-format Based on pair-style (hover mouse on pair-style)

# ------------------------- SETTINGS ---------------------------------
compute peratom all pe/atom             # calculating potentail energy (pe/atom) using this command (visit the link (https://docs.lammps.org/compute.html) to see the list of properties that we can calculate )
compute csym all centro/atom fcc        # centro-symmetry parameter for each atom (https://docs.lammps.org/compute_centro_atom.html)
                                        # 0= perfect lattice; 0.5-1.25= Existing defect/dislocation; 4-6=Stacking faults; ~ 23.0= Free surface 
                                        # Very useful to explain the defect mechanism. Use Ovito to explain the results using: (Centrosymme parameter+common neighbor analysis)

neighbor            0.2 bin             #  pairwise neighbor lists:  neighbor skin (0.2) style (bin)
neigh_modify        every 2 delay 10 check yes page 100000      # dealy 10 means it will creat new neighbor after 10 time steps 

######################################
# EQUILIBRATION
reset_timestep	0           # to start the count from 0
timestep 0.01               # delta_time value

velocity middle create 300 12345 mom yes rot no     # add velocity to adjust the atomic poisition during equilibration process
fix 1 middle npt temp 300 300 1 iso 0 0 1    # "fix" is same as 'compute'; instructs to do something 

thermo 1000         # A display function, same as printf, usually comes after the fix command
thermo_style custom step lx ly lz press pxx pyy pzz pe temp

run 2000        # Run for at least 20 picosecond (assuming 1 fs timestep)
unfix 1         # 'unfix' will enable the reuse of earlier fix-ID (here, is fix 1).
                # Not mandatory always.

write_data structure_Equillibriated.lmpdat nocoeff  # To save the equilibrated stucture data 

variable tmp equal "lz"     # Declearing a variable, name= tmp; # Store final cell length for strain calculations
variable L0 equal ${tmp}    # Syntax of calling a variable is "${V-name}""
print "Initial Length, L0: ${L0}"

######################################
# DEFORMATION
reset_timestep	0
timestep 0.01

fix		1 middle npt temp 300 300 1 x 0 0 1 y 0 0 1     # simulating npt ensembles, to make closer to the real situation
variable srate equal 1.0e10            # 1x10e10  mm/s 
variable srate1 equal "v_srate / 1.0e12"        # 1ps=10e-12 second therefore, 
fix		2 all deform 1 z erate ${srate1} units box remap x  # erate=0.01 per time stemp [The strain rate in LAMMPS for 0.015 mm/min would be 2.5 × 10⁻¹⁵ Å/fs.]

variable strain equal "(lz - v_L0)/v_L0"
variable p1 equal "v_strain"        # p2, p3, p4 are in GPa
variable p2 equal "-pxx/10000"      # for units metal, pressure is in [bars] = 100 [kPa] = 1/10000 [GPa]
variable p3 equal "-pyy/10000"
variable p4 equal "-pzz/10000"
fix def1 all print 100 "${p1} ${p2} ${p3} ${p4}" file Al_SC_100.def1.txt screen no # Output strain and stress info to file

# Use cfg for AtomEye
dump 		1 all cfg 100 dump.tensile_*.cfg mass type xs ys zs c_csym c_peratom fx fy fz  # 
#dump_modify 1 element Al
dump       2 all atom 1000 dump.final


thermo 	1000        # Display thermo
thermo_style	custom step v_strain temp v_p2 v_p3 v_p4 ke pe press

run		10000       # No. of run = strain/(strain rate x Step size) e.g. 0.30 (30%)/(1e-3 x 0.001)= 3,00,000 minimun

######################################
# SIMULATION DONE
print "All done"