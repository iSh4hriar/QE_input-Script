import numpy as np
import matplotlib.pyplot as plt

# =============================================================================
# ১. USER INPUT VARIABLES (এখানে আপনার ভ্যারিয়েবলগুলো বসান)
# =============================================================================

# (ক) ডাটা ফাইল ভ্যারিয়েবল
data_file = 'plane_001.txt'  # VESTA থেকে এক্সপোর্ট করা 2D ASCII/Grid ফাইলের নাম

# (খ) ল্যাটিস প্যারামিটার বা বাউন্ডারি ভ্যারিয়েবল (Angstrom এককে)
# আপনার রিল্যাক্সড scf.in ফাইল থেকে ল্যাটিস কনস্ট্যান্ট 'a' এর মান এখানে বসাবেন।
lattice_constant = 4.50  # ধরলাম ল্যাটিস প্যারামিটার ৪.৫০ অ্যাংস্ট্রম
extent_scale = [0, lattice_constant, 0, lattice_constant]

# (গ) ভিজ্যুয়ালাইজেশন ও কালার ভ্যারিয়েবল
color_map = 'jet'         # পেপারের মতো রেড-ইয়েলো-ব্লু টোনের জন্য 'jet' বা 'turbo' বেস্ট
contour_lines = 15        # চার্জ ডেনসিটির বর্ডার লাইনের সংখ্যা (বাড়িয়ে-কমিয়ে রিং এডজাস্ট করতে পারবেন)
font_size_atoms = 14      # পরমাণুর নামের ফন্ট সাইজ
font_family = 'Arial'     # পেপার স্টাইল ফন্ট

# (ঘ) পরমাণুর পজিশন ও লেবেল ভ্যারিয়েবল (অ্যাটম ম্যাপিং)
# ছবিতে যেভাবে আছে: কর্নারে O, সেন্টারে I, এবং এজে K/Rb/Cs
# ফরম্যাট: (X-কোঅর্ডিনেট, Y-কোঅর্ডিনেট, 'পরমাণুর নাম')
atoms_to_plot = [
    (0.0, 0.0, 'O'),   # নিচের বাম কর্নার
    (0.0, lattice_constant, 'O'),   # উপরের বাম কর্নার
    (lattice_constant, 0.0, 'O'),   # নিচের ডান কর্নার
    (lattice_constant, lattice_constant, 'O'),   # উপরের ডান কর্নার
    
    (lattice_constant/2, lattice_constant/2, 'I'), # একদম মাঝখানের সেন্ট্রাল অ্যাটম
    
    (lattice_constant/2, 0.0, 'K'),   # নিচের এজ-সেন্টার
    (lattice_constant/2, lattice_constant, 'K'),   # উপরের এজ-সেন্টার
    (0.0, lattice_constant/2, 'K'),   # বামের এজ-সেন্টার
    (lattice_constant, lattice_constant/2, 'K')    # ডানের এজ-সেন্টার
]

# =============================================================================
# ২. প্লটিং প্রসেস (এখানে কোনো কিছু পরিবর্তন করার প্রয়োজন নেই)
# =============================================================================

# VESTA এর ডাটা লোড করা
try:
    data = np.loadtxt(data_file)
except Exception as e:
    print(f"Error loading file: {e}. প্লিজ নিশ্চিত করুন ফাইলের পাথ সঠিক আছে।")
    data = np.random.rand(100, 100) # ফাইল না থাকলে ডেমো রান করার জন্য

fig, ax = plt.subplots(figsize=(6, 6))

# স্মুথ কালার ফিলিং (Contourf)
filled_contour = ax.imshow(data, cmap=color_map, origin='lower', extent=extent_scale)

# পেপারের মতো কালো রঙের চিকন বর্ডার রিং বা লাইন (Contours)
ax.contour(data, levels=contour_lines, colors='black', linewidths=0.4, origin='lower', extent=extent_scale)

# অক্ষ বা চারপাশের টিকস ও নাম্বার মুছে ফেলা (হুবহু পেপার ফরম্যাট)
ax.set_xticks([])
ax.set_yticks([])

# পরমাণুর নামগুলো নির্দিষ্ট জায়গায় বসানো
for x, y, label in atoms_to_plot:
    ax.text(x, y, label, fontsize=font_size_atoms, fontweight='bold', 
            fontname=font_family, ha='center', va='center', color='black',
            bbox=dict(facecolor='white', alpha=0.6, edgecolor='none', pad=1)) # লেখার পেছনে হালকা সাদা ব্যাকগ্রাউন্ড যাতে স্পষ্ট পড়া যায়

# ইমেজ সেভ করা (Publication Quality - 300 DPI)
plt.tight_layout()
plt.savefig('charge_density_publication.png', dpi=300, bbox_inches='tight')
print("অভিনন্দন! আপনার পেপার স্টাইল প্লটটি 'charge_density_publication.png' নামে সেভ হয়েছে।")
plt.show()
