import matplotlib.pyplot as plt

# ডাটা লিস্ট তৈরি
ecut = []
energy = []

# ফাইলটি রিড করা
with open("calc-ecut.dat", "r") as f:
    for line in f:
        coords = line.split()
        if len(coords) >= 2:
            ecut.append(float(coords[0]))
            energy.append(float(coords[1]))

# গ্রাফ বা প্লট তৈরি করা
plt.figure(figsize=(8, 5))
plt.plot(ecut, energy, marker='o', linestyle='-', color='red', label='Total Energy')

# লেবেল এবং টাইটেল যোগ করা
plt.title("Convergence Test: Cut-off Energy", fontsize=14, fontweight='bold')
plt.xlabel("Cut-off Energy (Ry)", fontsize=12)
plt.ylabel("Total Energy (Ry)", fontsize=12)
plt.grid(True, linestyle='--', alpha=0.6)
plt.legend()

# গ্রাফটি স্ক্রিনে দেখানোর জন্য
plt.show()
